{
  "name": "chess",
  "version": "0.1.20",
  "private": true,
  "scripts": {
    "build": "next build",
    "sync-games": "npx tsx lib/sync-games.ts",
    "deconstruct-games": "npx tsx lib/deconstruct-games.ts",
    "cron-sync": "npx tsx lib/cron-sync.ts",
    "cron-build-tree": "npx tsx lib/cron-build-tree.ts",
    "cron-sync-tpos": "npx tsx lib/cron-sync-tpos.ts",
    "cron-purge": "npx tsx lib/cron-purge.ts",
    "cron-evaluate-positions": "npx tsx lib/cron-evaluate-positions.ts",
    "cron-update-cp-change": "npx tsx lib/cron-update-cp-change.ts",
    "cron-build-habits": "npx tsx lib/cron-build-habits.ts",
    "cron-evaluate-game-endings": "npx tsx lib/cron-evaluate-game-endings.ts",
    "cron-deepen-popular": "npx tsx lib/cron-deepen-popular.ts",
    "cron-full": "npm run cron-sync && npm run cron-build-tree && npm run cron-sync-tpos && npm run cron-purge && npm run cron-evaluate-positions && npm run cron-update-cp-change && npm run cron-build-habits && npm run cron-evaluate-game-endings && npm run cron-deepen-popular",
    "locallocal": "copy /Y .env.locallocal .env && next dev --turbopack --port 4050",
    "localprod": "copy /Y .env.localprod .env && next dev --turbopack --port 4052"
  },
  "dependencies": {
    "@heroicons/react": "2.2.0",
    "@neondatabase/serverless": "1.1.0",
    "chess.js": "1.4.0",
    "dotenv": "17.4.2",
    "next": "16.2.9",
    "nextjs-shared": "github:richardstuart007/nextjs-shared",
    "pg": "8.21.0",
    "react": "19.2.7",
    "react-chessboard": "5.10.0",
    "react-dom": "19.2.7",
    "react-is": "19.2.7",
    "recharts": "3.8.1",
    "stockfish": "18.0.8",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.1",
    "@types/node": "25.9.3",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "tailwindcss": "4.3.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
